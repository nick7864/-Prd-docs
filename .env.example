# PRD Triage Agent — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# === Required for LLM-based agents ===
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-key-here

# === Optional: Alternative key variable name ===
# ADK accepts either GOOGLE_API_KEY or GEMINI_API_KEY
# GEMINI_API_KEY=your-key-here

# === Optional: Switch to a non-Gemini model (GLM / OpenAI / any OpenAI-compatible endpoint) ===
# Default is Gemini (no TRIAGE_MODEL_* needed). To route all agents through an
# OpenAI-compatible endpoint instead, uncomment and fill all four:
# TRIAGE_MODEL_PROVIDER=openai_compat
# TRIAGE_MODEL=glm-5.2                 # bare name is auto-prefixed with openai/
# TRIAGE_API_BASE=https://your-endpoint/api/v1
# TRIAGE_API_KEY=your-key              # ZHIPUAI_API_KEY / OPENAI_API_KEY also accepted

# === Optional: Cloud Run deployment (D6.2) ===
# GCP_PROJECT=your-gcp-project-id
# GCP_REGION=asia-east1
